generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum IssueStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ActivityAction {
  ORGANIZATION_CREATED
  PROJECT_CREATED
  ISSUE_CREATED
  ISSUE_STATUS_CHANGED
  ISSUE_ASSIGNED
  COMMENT_CREATED
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  image         String?
  memberships   Membership[]
  assignedIssues Issue[]       @relation("IssueAssignee")
  createdIssues Issue[]        @relation("IssueReporter")
  comments      Comment[]
  activities    ActivityLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Organization {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  memberships Membership[]
  projects    Project[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  role           MembershipRole @default(MEMBER)
  userId         String
  organizationId String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Project {
  id             String        @id @default(cuid())
  name           String
  key            String
  description    String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  issues         Issue[]
  activities     ActivityLog[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}

model Issue {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      IssueStatus   @default(TODO)
  priority    IssuePriority @default(MEDIUM)
  dueDate     DateTime?
  projectId   String
  assigneeId  String?
  reporterId  String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?         @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter    User          @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  comments    Comment[]
  activities  ActivityLog[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([projectId, status])
  @@index([projectId, priority])
  @@index([assigneeId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String
  issueId   String
  authorId  String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([issueId])
}

model ActivityLog {
  id        String         @id @default(cuid())
  action    ActivityAction
  metadata  Json?
  projectId String?
  issueId   String?
  actorId   String
  project   Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issue     Issue?         @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor     User           @relation(fields: [actorId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@index([projectId, createdAt])
  @@index([issueId, createdAt])
}
